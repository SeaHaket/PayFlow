# PayFlow — Environment Variables
# Copy to .env and fill in values

# App name shown in browser tab (optional)
VITE_APP_NAME=PayFlow

# Chain ID: 42220 = Celo Mainnet, 11142220 = Celo Sepolia (testnet)
# Leave blank — wagmi config handles both automatically
# VITE_CHAIN_ID=42220

# No secrets needed for v1 — everything runs client-side via MiniPay's
# injected window.ethereum provider
